# GoTok configuration.
#
# Copy this file to `.env` and adjust as needed. Values may also be provided
# directly via the real process environment (e.g. in production); `.env` is only
# loaded when present. All variables are optional — defaults are shown below.

# Directory for uploads and the persisted cookie secret.
# GOTOK_DATA_DIR=data

# Upload directory (defaults to <GOTOK_DATA_DIR>/uploads when unset).
# GOTOK_UPLOAD_DIR=data/uploads

# PostgreSQL connection string. Required — no SQLite fallback.
# Supports horizontal scaling (multiple writer instances share one database).
GOTOK_DATABASE_URL=postgres://gotok:gotok@localhost:5432/gotok?sslmode=disable

# Redis address for WebSocket pub/sub (cross-instance message routing) and
# online-presence tracking. Required for real-time chat.
GOTOK_REDIS_ADDR=localhost:6379

# Address the HTTP server listens on.
# GOTOK_LISTEN_ADDR=:8080

# Maximum video upload size, in megabytes.
# GOTOK_MAX_UPLOAD_MB=200

# Cookie signing secret. Leave empty to auto-generate and persist under
# GOTOK_DATA_DIR/cookie_secret (recommended for local dev).
# GOTOK_COOKIE_SECRET=

# Development mode: enables dev-only features such as the Swagger UI at
# /swagger/index.html. Keep false in production.
# GOTOK_DEV=false
