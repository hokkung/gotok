#!/usr/bin/env bash
set -euo pipefail

GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' ':!vendor/' || true)
[ -z "$GO_FILES" ] && exit 0

# Auto-format + re-stage.
gofmt -s -w $GO_FILES
git add $GO_FILES

# Vet (blocking).
if ! go vet ./... 2>&1; then
	echo "❌ go vet failed"
	exit 1
fi

# Lint (blocking).
if command -v golangci-lint >/dev/null 2>&1; then
	if ! golangci-lint run ./... 2>&1; then
		echo "❌ golangci-lint failed (bypass: --no-verify)"
		exit 1
	fi
fi
